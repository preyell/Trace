<!-- src/main/resources/logback-spring.xml -->
<configuration scan="true" scanPeriod="60 seconds">

  <!-- Central place for the directory; can be overridden by env/props -->
  <property name="LOG_DIR" value="D:/trace_log"/>
  <property name="LOG_NAME" value="trace-app"/>

  <!-- Console (optional but handy) -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%X{reqId}] %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Rolling file appender -->
  <appender name="ROLLING" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_DIR}/${LOG_NAME}.log</file>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%X{reqId}] %logger{36} - %msg%n</pattern>
    </encoder>

    <!-- Roll daily and when a file exceeds 50MB, keep 14 days, cap total at 2GB -->
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${LOG_DIR}/${LOG_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>50MB</maxFileSize>
      <maxHistory>14</maxHistory>
      <totalSizeCap>2GB</totalSizeCap>
    </rollingPolicy>
  </appender>

  <!-- Your package: DEBUG in dev -->
  <logger name="com.sybyl.trace" level="DEBUG" additivity="false">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="ROLLING"/>
  </logger>

  <!-- Root: INFO -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="ROLLING"/>
  </root>
</configuration>
